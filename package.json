    "patch": "npm version patch",
    "minor": "npm version minor && npm run push-version",
    "major": "npm version major && npm run push-version",
    "build": "tsc && npx eslint . && node dist/build.js ",
    "test": "tsc && node --test dist/rss.test.js dist/sheets.test.js dist/index.test.js"
  },
  "devDependencies": {
